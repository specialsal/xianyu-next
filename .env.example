# ================================
# 闲鱼自动回复系统 - 环境变量配置示例
# ================================
# 复制此文件为 .env 并填写实际配置

# ==================== API 服务配置 ====================
# API 服务主机地址
API_HOST=0.0.0.0

# API 服务端口
API_PORT=8080

# ==================== Cookie 配置 ====================
# 闲鱼 Cookie 字符串（单账号）
# COOKIES_STR=your_cookie_here

# ==================== 数据库配置 ====================
# 数据库文件路径（可选，默认为 data/xianyu.db）
# DB_PATH=data/xianyu.db

# ==================== 日志配置 ====================
# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ==================== 安全配置 ====================
# JWT 密钥（用于用户认证，请修改为随机字符串）
JWT_SECRET_KEY=your-secret-key-change-me

# ==================== AI 回复配置 ====================
# OpenAI API Key（可选，用于 AI 自动回复）
# OPENAI_API_KEY=your_openai_api_key

# OpenAI API Base URL（可选，用于自定义 API 端点）
# OPENAI_API_BASE=https://api.openai.com/v1

# ==================== 说明 ====================
# 1. 复制此文件为 .env
# 2. 根据实际情况修改配置值
# 3. 不要将 .env 文件提交到版本控制
